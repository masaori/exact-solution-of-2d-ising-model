# ---------------------------------------------------------
# SageMath: Step 17 因数分解の検証
# 対象: parts/008_.../028_claim_a_theta_mu.typ Step 17
# 式ペア: (c_1+1)*(1-alpha_1*x)*(1-alpha_2^(-1)*x) = (c_1-1)*x^2 - 2*s_1*c_2*x + (c_1+1)
# ---------------------------------------------------------
import os
_dir = os.path.dirname(os.path.abspath(__file__)) if '__file__' in dir() else '.'
load(os.path.join(_dir, '../../_shared/defs.sage'))

x = exp(i*theta_mu)

# ---------------------------------------------------------
# 式1: (c_1+1)*(1-alpha_1*x)*(1-alpha_2^(-1)*x)
# ---------------------------------------------------------
# 式1(typst):
# (c_1 + 1)(1 - alpha_1 x)(1 - alpha_2^(-1) x)
expr1 = (c_1 + 1) * (1 - alpha_1*x) * (1 - (1/alpha_2)*x)

# ---------------------------------------------------------
# 式2: (c_1-1)*x^2 - 2*s_1*c_2*x + (c_1+1)
# ---------------------------------------------------------
# 式2(typst):
# (c_1 + 1) - 2 s_1 c_2 x + (c_1 - 1) x^2
expr2 = (c_1 + 1) - 2*s_1*c_2*x + (c_1 - 1)*x^2

# ---------------------------------------------------------
# 検証
# ---------------------------------------------------------
# K1=10.4 で (c_1+1)~5e8 のため積が ~1e10 になり、絶対誤差 ~1e-5 は相対誤差 ~1e-15
numerical_check(expr1, expr2, tol=1e-3, label="Step 17: factorization check")
